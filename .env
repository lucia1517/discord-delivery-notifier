# =====================================================
# Discord Delivery Notifier
# Environment Variables
# =====================================================

# -------------------------
# Google Cloud
# -------------------------

GOOGLE_CLOUD_PROJECT=discord-delivery-notifier

PUBSUB_TOPIC=gmail-push


# -------------------------
# Discord
# -------------------------

DISCORD_WEBHOOK_URL=


# -------------------------
